# ─── Gmail Credentials ───────────────────────────────────────────────────────
# Your Gmail address (e.g. yourname@gmail.com)
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your normal password!)
# How to get: Google Account → Security → 2-Step Verification → App Passwords
# Generate one for "Mail" and paste here (16 characters, no spaces)
GMAIL_PASS=your_16_char_app_password

# ─── Recipient Email ─────────────────────────────────────────────────────────
# Where job alert emails will be sent (can be same as GMAIL_USER)
RECIPIENT_EMAIL=recipient@gmail.com

# ─── RapidAPI Key (JSearch) ──────────────────────────────────────────────────
# Get FREE key at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month (enough for daily runs)
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Gemini API Key (Feature 2 & 3: AI Scoring + Cover Letter) ───────────────
# Get FREE key at: https://aistudio.google.com/apikey
# Free tier: 60 requests/minute (more than enough for daily runs)
# Without this key, AI scoring uses keyword heuristics & cover letter uses template
GEMINI_API_KEY=your_gemini_api_key_here
